{
  "_comment": "훅 실습용 — 학습자가 본인 Claude Code 또는 Copilot CLI .claude/settings.json 또는 ~/.claude/settings.json 에 복사. POS_OPS_ROOT 환경변수에 본 repo path 지정.",

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__pos-ops__detect_anomaly",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${POS_OPS_ROOT}/hooks/on_anomaly.py"
          }
        ]
      }
    ],

    "PreToolUse": [
      {
        "matcher": "mcp__pos-ops__create_ticket",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${POS_OPS_ROOT}/hooks/guard_ticket.py"
          }
        ]
      }
    ],

    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${POS_OPS_ROOT}/hooks/morning_brief.py"
          }
        ]
      }
    ]
  }
}
